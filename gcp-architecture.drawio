          <mxPoint x="460" y="270"/>
        </Array>
      </mxGeometry>
    </mxCell>
    
    <!-- Impersonate -->
    <mxCell id="edge_impersonate" value="4. Impersonate (.tf)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" source="workload_identity" target="service_account" parent="1">
