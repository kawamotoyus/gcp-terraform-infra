    </mxCell>

    <!-- Google Cloud Platform -->
    <mxCell id="gcp_group" value="Google Cloud Platform (gcp-lab-488301)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="500" y="80" width="400" height="560" as="geometry"/>
    </mxCell>

    <!-- Workload Identity -->
    <mxCell id="workload_identity" value="Workload Identity&#10;(Pool &amp; Provider)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="gcp_group">
      <mxGeometry x="30" y="160" width="120" height="60" as="geometry"/>
    </mxCell>
    
    <mxCell id="service_account" value="Service Account&#10;(terraform-ci-sa)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="gcp_group">
      <mxGeometry x="30" y="260" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- GCS Backend -->
    <mxCell id="gcs_bucket" value="Cloud Storage&#10;(tfstate Backend)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="gcp_group">
      <mxGeometry x="250" y="160" width="100" height="80" as="geometry"/>
    </mxCell>

    <!-- Cloud Run -->
    <mxCell id="cloud_run" value="Cloud Run&#10;(Nginx Service)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="gcp_group">
      <mxGeometry x="240" y="380" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- End Users -->
    <mxCell id="all_users" value="All Users&#10;(Internet)" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="950" y="450" width="60" height="80" as="geometry"/>
    </mxCell>

    <!-- Connections -->
    <!-- Push code -->
    <mxCell id="edge_push" value="1. Git Push (Code)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" source="developer" target="github_repo" parent="1">
