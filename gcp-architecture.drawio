    <!-- Manage State -->
    <mxCell id="edge_state" value="5. Read/Write State" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;dashed=1;" edge="1" source="service_account" target="gcs_bucket" parent="1">
