    </mxCell>

    <!-- Trigger -->
    <mxCell id="edge_trigger" value="2. Trigger" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" source="github_repo" target="github_actions" parent="1">
